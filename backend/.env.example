# ============================================================
# IndustrialBrain — Backend Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# Application
APP_NAME=IndustrialBrain
APP_PORT=8000

# JWT / Auth
SECRET_KEY=change-this-to-a-random-64-char-string-before-demo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# PostgreSQL
DATABASE_URL=postgresql://industrialbrain:industrialbrain123@localhost:5432/industrialbrain

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=industrialbrain123

# ChromaDB (runs on 8001 externally, 8000 internally in Docker)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_DOCUMENTS=industrial_documents

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Gemini (get free key from https://aistudio.google.com)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=8192

# Groq LLM configuration
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=8192
GROQ_TEMPERATURE=0.1

# Embeddings (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ML model paths (relative to project root)
FAILURE_MODEL_PATH=ml/predictive_maintenance/models/failure_rf_model.pkl
SCALER_PATH=ml/predictive_maintenance/models/scaler.pkl
ANOMALY_MODEL_PATH=ml/predictive_maintenance/models/iso_forest.pkl
PID_MODEL_PATH=ml/pid_parser/models/pid_yolov8.pt

# Data paths
SAMPLE_DOCUMENTS_DIR=data/sample_documents
SEEDS_DIR=data/seeds
