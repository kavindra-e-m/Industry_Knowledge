# IndustrialBrain — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your values
# Get Gemini API key FREE from: https://aistudio.google.com

# Application
APP_NAME=IndustrialBrain
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-this-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=industrialbrain
POSTGRES_USER=industrialbrain
POSTGRES_PASSWORD=industrialbrain123
DATABASE_URL=postgresql://industrialbrain:industrialbrain123@localhost:5432/industrialbrain

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=industrialbrain123

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_DOCUMENTS=industrial_documents
CHROMA_COLLECTION_REGULATIONS=industrial_regulations

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# LLM — Get FREE key from https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=8192

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ML Models
ML_MODELS_PATH=ml/predictive_maintenance/models
YOLO_MODEL_PATH=ml/pid_parser/models/pid_yolov8.pt

# File Storage
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=50

# SKAB Dataset
SKAB_DATA_PATH=data/raw/skab

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/alerts
